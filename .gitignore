# OS/editor noise
.DS_Store
.idea/

# Local Stellar / Soroban build artifacts
test-ledger/

# Soroban / Stellar CLI local cache (when present)
.stellar/

# Secrets at repo root (do not use `.env*` — would ignore `.env.example`)
.env
.env.local
.env.*.local

# Circom Powers of Tau at workspace root (large; fetch via script or docs)
*.ptau

# Logs
*.log

# Rust/Cargo build outputs
target/**
# Nested workspace build dirs (e.g. contracts/target) — the root-anchored
# pattern above does not match these.
**/target/

# Soroban test snapshots generated by `cargo test`
**/test_snapshots/

# Keep deploy keypairs versioned to preserve contract IDs across machines
!target/deploy/
!target/deploy/*-keypair.json

v2.md
guide.md
I.md
n.md
# Ignore contract test snapshots
contracts/**/test_snapshots/
contracts/Cargo.lock
